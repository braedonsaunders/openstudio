# OpenStudio Environment Configuration
# Copy this file to .env.local and fill in your values

# =============================================================================
# SUPABASE CONFIGURATION (Required)
# =============================================================================

# Your Supabase project URL (client-side accessible)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Your Supabase anon/public key (client-side accessible)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Your Supabase service role key (server-side only - for API routes)
# This bypasses RLS and should NEVER be exposed to the client
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# =============================================================================
# GOOGLE LYRIA AI MUSIC GENERATION (Required for AI features)
# =============================================================================

# Google Gemini/Lyria API key (SERVER-SIDE ONLY)
# This key is used by /api/lyria/connect to authenticate with Google's API
# It is NEVER exposed to the client - the client authenticates with Supabase
# and the server proxies the request with the API key
#
# Get your key from: https://aistudio.google.com/app/apikey
GOOGLE_GEMINI_API_KEY=your-gemini-api-key

# =============================================================================
# DEPRECATED - DO NOT USE
# =============================================================================
# The following variable is no longer used and should NOT be set.
# The API key is now stored server-side only for security.
#
# NEXT_PUBLIC_GOOGLE_GEMINI_API_KEY=  # <-- REMOVED - DO NOT SET

# =============================================================================
# CLOUDFLARE (Required for WebRTC audio)
# =============================================================================

# Cloudflare Calls API credentials for WebRTC audio streaming
CLOUDFLARE_ACCOUNT_ID=your-account-id
NEXT_PUBLIC_CLOUDFLARE_CALLS_APP_ID=your-app-id
CLOUDFLARE_CALLS_APP_SECRET=your-app-secret

# TURN server credentials (SERVER-SIDE ONLY - fetched via /api/webrtc/turn-credentials)
# These are used for NAT traversal when direct connections fail
CLOUDFLARE_TURN_USERNAME=your-turn-username
CLOUDFLARE_TURN_CREDENTIAL=your-turn-credential

# Guest ID signing secret (SERVER-SIDE ONLY)
# Used to cryptographically sign guest user IDs to prevent spoofing
# If not set, derived from SUPABASE_SERVICE_ROLE_KEY
# GUEST_ID_SECRET=your-random-secret-at-least-32-chars

# =============================================================================
# CLOUDFLARE R2 STORAGE (Required for audio file storage)
# =============================================================================

CLOUDFLARE_R2_ACCOUNT_ID=your-account-id
CLOUDFLARE_R2_ACCESS_KEY_ID=your-access-key
CLOUDFLARE_R2_SECRET_ACCESS_KEY=your-secret-key
CLOUDFLARE_R2_BUCKET_NAME=openstudio

# Optional: Custom endpoint for R2-compatible storage
# CLOUDFLARE_R2_ENDPOINT=https://your-account.r2.cloudflarestorage.com

# =============================================================================
# YOUTUBE API (Optional - for YouTube integration)
# =============================================================================

# YouTube Data API key for video search and playback
# YOUTUBE_API_KEY=your-youtube-api-key

# =============================================================================
# SAM/AUDIODEC BACKEND (Optional - for AI stem separation)
# =============================================================================

# Backend service URLs for AI audio processing
# SAM_BACKEND_URL=http://localhost:8000
# AUDIODEC_BACKEND_URL=http://localhost:8001
